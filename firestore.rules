rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "g0930035@gmail.com";
    }

    // イベント本体
    // 一般ユーザーは閲覧のみ
    // create/update は廃止（races は書き込み先ではなく read + deleteEvent 用）
    match /races/{raceId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // 投票
    // 一般ユーザーも投票できる
    // 削除は管理者だけ
    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // My AI
    // 一般ユーザーも作成はできる
    // 編集・削除は管理者だけ
    match /myAis/{aiId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // events コレクション(新)
    // 一般ユーザーは閲覧できる
    // 作成・編集・削除は管理者だけ
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // predictions サブコレクション
      match /predictions/{predictionId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      // Result correction audit records.
      // correctedBy may contain admin uid/email, so reads are admin-only.
      // Revision records are immutable after creation.
      match /resultRevisions/{revisionId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // collectionGroup("predictions") 用（読み取りのみ）
    // 一覧画面が全イベントの予測をまとめて読むために必要
    match /{path=**}/predictions/{predictionId} {
      allow read: if true;
    }

    // 上記以外のコレクションはすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
